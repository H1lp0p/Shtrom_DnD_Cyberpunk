# Obsidian — состояние и кэш
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/app.json
.obsidian/appearance.json
.obsidian/graph.json
.obsidian/cache/

# Темы (опционально: раскомментируй, если не синхронизируешь темы)
